# Prompt Compression Engine — Environment Variables
# Copy to .env and modify as needed.

# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_SHUTDOWN_TIMEOUT=10s

# Compressor
COMPRESSOR_MAX_KEYWORDS=8
COMPRESSOR_MIN_WORD_LENGTH=3
COMPRESSOR_POSITION_BOOST=1.5
COMPRESSOR_LENGTH_THRESHOLD=5
COMPRESSOR_LENGTH_BONUS=1.2

# Rate Limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
